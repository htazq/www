{
  "name": "haitang's-digital-space",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "check": "node --check scripts/local-dashboard-build.mjs && node --check scripts/validate-dashboard.mjs && node --check scripts/test-dashboard-external-contributions.mjs && npm run validate && npm run test:contributions",
